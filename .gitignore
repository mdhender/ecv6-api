# Environment files (see internal/dotenv). The *.local files may hold secrets, so
# they are explicity ignored; shared .env and .env.<env> files are committed.
.env.local
.env.*.local

# SQLite databases built by `ecdb create` (and their sidecar files). These are
# disposable build products, rebuilt from data files; the data folders (e.g.
# data/claude, data/alpha) may still hold committed input files.
ec.db
ec.db-*

# OS / editor cruft
.DS_Store

# Inherited v4 OpenAPI — kept locally as the reconciliation baseline, not
